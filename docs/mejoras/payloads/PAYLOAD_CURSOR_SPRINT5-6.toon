# INSTRUCCIONES S5.2
instruccion_s52:
  Crear en lib/prompt-templates.ts:
  - PROMPT_PENAL: "Contexto: Derecho penal colombiano. Cita artículos del Código Penal (Ley 599/2000) con exactitud. Incluye penas, tipos penales, elementos del delito."
  - PROMPT_ADMINISTRATIVO: "Contexto: Derecho administrativo colombiano. Cita CPACA (Ley 1437/2011) y Ley 80/1993. Incluye términos, recursos, procedimientos."
  - PROMPT_CONSTITUCIONAL: "Contexto: Derecho constitucional. Cita Constitución 1991 y sentencias Corte Constitucional."
  - getPromptByArea(query): detectar área por keywords:
    penal: delito, hurto, estafa, pena, delincuente
    admin: nulidad, recurso, petición, CPACA, término
    constitucional: tutela, emergencia, Corte Constitucional, derechos fundamentales

